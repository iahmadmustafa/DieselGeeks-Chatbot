# WooCommerce REST API (read-only key)
WOOCOMMERCE_URL=https://dieselgeeks.com.au
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sync endpoint protection (Vercel cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# OpenAI — fitment parse fallback + chat assistant
OPENAI_API_KEY=
FITMENT_LLM_MODEL=gpt-5-mini
FITMENT_LLM_MAX_OUTPUT_TOKENS=2000
FITMENT_LLM_REASONING_EFFORT=low
FITMENT_LLM_CONCURRENCY=8

# Chat assistant (Phase 2)
CHAT_MODEL=gpt-5-mini
CHAT_MAX_OUTPUT_TOKENS=800
CHAT_MAX_MESSAGE_LENGTH=500
CHAT_MAX_HISTORY_MESSAGES=20
CONTACT_URL=https://dieselgeeks.com.au/contact-us/
# Comma-separated list of browser Origin values allowed to call POST /api/chat.
# Include localhost entries for local widget testing. In `next dev`, localhost
# origins are also auto-allowed even if omitted here.
ALLOWED_ORIGINS=https://dieselgeeks.com.au,https://stage2.dieselgeeks.com.au,http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
